generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Member {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String    @unique
  active         Boolean   @default(true)
  debtOverride   Float?
  debtOverrideOn DateTime?
  debtPaidOn     DateTime?
  orders         Order[]
}

model Dish {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  active Boolean @default(true)
  orders Order[]
}

model OrderSession {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime       @unique
  note      String?
  totalBill Float?
  orders    Order[]
  images    SessionImage[]
}

model SessionImage {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String       @db.ObjectId
  data      String
  filename  String
  createdAt DateTime     @default(now())
  session   OrderSession @relation(fields: [sessionId], references: [id])
}

model Feedback {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  message   String
  createdAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  detail    String
  createdAt DateTime @default(now())
}

model Order {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  memberId  String       @db.ObjectId
  dishId    String       @db.ObjectId
  sessionId String       @db.ObjectId
  unitPrice Float
  paid      Boolean      @default(false)
  member    Member       @relation(fields: [memberId], references: [id])
  dish      Dish         @relation(fields: [dishId], references: [id])
  session   OrderSession @relation(fields: [sessionId], references: [id])
}
